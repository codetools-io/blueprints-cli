{
  "name": "@codetools/blueprints-cli",
  "type": "module",
  "version": "2.0.0-rc.1",
  "description": "A tool for generating predefined files and directories",
  "private": false,
  "main": "./app/cli.mjs",
  "repository": {
    "type": "git",
    "url": "https://github.com/codetools-io/blueprints-cli"
  },
  "bin": {
    "bp": "./app/cli.mjs",
    "bp-mcp": "./bin/mcp-server.mjs"
  },
  "scripts": {
    "postinstall": "mkdir -p ~/.blueprints",
    "test": "vitest run",
    "test-watch": "vitest",
    "test-debug": "vitest run --reporter=verbose",
    "test-coverage": "vitest run --coverage"
  },
  "keywords": [
    "node",
    "cli",
    "scaffold",
    "generate",
    "boilerplate",
    "automation",
    "workflow",
    "template"
  ],
  "author": "Cliff Pyles <cliff@cliffpyles.com>",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.1",
    "prettier": "^3.8.1",
    "vitest": "^4.1.1"
  },
  "dependencies": {
    "@langchain/anthropic": "^1.3.25",
    "@langchain/core": "^1.1.35",
    "@langchain/google-genai": "^2.1.26",
    "@langchain/openai": "^1.3.0",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "date-fns": "^4.1.0",
    "dot-prop": "^10.1.0",
    "find-up": "^8.0.0",
    "fs-extra": "^11.3.4",
    "globby": "^16.1.1",
    "inflection": "^3.0.2",
    "lodash": "^4.17.23",
    "lodash-es": "^4.17.23",
    "rc": "^1.2.6",
    "treeify": "^1.1.0",
    "yaml": "^2.3.4",
    "zod": "^4.3.6"
  }
}
